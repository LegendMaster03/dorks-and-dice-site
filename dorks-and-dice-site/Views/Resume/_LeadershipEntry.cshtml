@model dorks_and_dice_site.Models.Resume.LeadershipEntryViewModel

<div class="@Model.CardCssClass">
    <div class="card-body">
        <h3 class="h6 mb-1">@Model.Title</h3>
        <p class="resume-entry-meta text-muted mb-2">@Model.DateRange</p>
        @if (!string.IsNullOrWhiteSpace(Model.RelatedProjectAction) && !string.IsNullOrWhiteSpace(Model.RelatedProjectLabel))
        {
            <p class="mb-2 small text-muted">
                Related project:
                <a class="fw-semibold" asp-controller="Resume" asp-action="@Model.RelatedProjectAction">@Model.RelatedProjectLabel</a>
            </p>
        }
        @if (Model.Highlights.Count > 0)
        {
            <ul class="mb-0">
                @foreach (var highlight in Model.Highlights)
                {
                    <li>@highlight</li>
                }
            </ul>
        }
        @if (!string.IsNullOrWhiteSpace(Model.PrimaryAction))
        {
            <p class="mt-2 mb-0">
                <a class="btn btn-sm btn-outline-primary resume-entry-action" asp-controller="Resume" asp-action="@Model.PrimaryAction">
                    @(string.IsNullOrWhiteSpace(Model.PrimaryActionText) ? "Open project" : Model.PrimaryActionText)
                </a>
            </p>
        }
    </div>
</div>
