@{
    ViewData["Title"] = "Experience: UNF Cyber Security Team";
    var header = new dorks_and_dice_site.Models.Resume.ResumeDetailHeaderViewModel
    {
        Title = "Experience: UNF Cyber Security Team",
        Subtitle = "UNF Cyber Security Team",
        MetaLine = "Web Specialist and Windows Specialist | 2024 - Present | Jacksonville, FL",
        LogoUrl = Url.Content("~/images/logos/osec-logo-full.png"),
        LogoAltText = "Osprey Security (OSEC) logo",
        LogoLinkUrl = "https://unfcyber.org",
        LogoAriaLabel = "UNF Cyber Security Team website"
    };
}

@await Html.PartialAsync("_ResumeDetailHeader", header)

<figure class="mb-3">
    <img src="~/images/cybersecurity/unf-cptc-regionals-2025.jpg"
         class="img-fluid rounded border"
         alt="UNF Cyber Security Team at CPTC Regionals in November 2025"
         width="800"
         height="600" />
    <figcaption class="text-muted mt-2">
        Team photo from CPTC Regionals, November 2025.
    </figcaption>
</figure>

<p>
    This role focuses on practical cybersecurity problem-solving in a team-based competitive environment.
    Work includes repeatable training methods, web and Windows challenge preparation, and process improvement.
</p>

<ul>
    <li>Participated in team preparation for collegiate cybersecurity competitions.</li>
    <li>Practiced structured workflows for web and Windows-focused security scenarios.</li>
    <li>Attended team practices and security lectures from external experts.</li>
</ul>

<section class="mt-4">
    <h2 class="h5">Results</h2>
    <ul>
        <li>Sustained active team participation across competition preparation cycles.</li>
        <li>Contributed to repeatable process planning for web and Windows challenge workflows.</li>
    </ul>
</section>

<section class="mt-4">
    <h2 class="h5">Tech Used</h2>
    <p class="mb-0">
        Cybersecurity, Patch Management, Back-End Web Development, Front-End Development, HTML5, HTML, Leadership.
    </p>
</section>

<section class="mt-4">
    <h2 class="h5">Related Project</h2>
    <p>
        During my last semester, I shifted from competition participation to a directed independent study under
        Professor <a href="https://www.linkedin.com/in/jscottkelly/" target="_blank" rel="noopener noreferrer">J. Scott Kelly</a>.
        The project focused on why our team underperformed, why peer schools performed better, and what process changes were needed to improve outcomes.
    </p>
    <p class="mb-0">
        <a class="btn btn-sm btn-outline-primary"
           asp-controller="Resume"
           asp-action="CyberSecurityTeam">
            Open Directed Independent Study
        </a>
    </p>
</section>
