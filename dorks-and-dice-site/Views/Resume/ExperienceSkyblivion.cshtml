@{
    ViewData["Title"] = "Experience: Skyblivion";
    var header = new dorks_and_dice_site.Models.Resume.ResumeDetailHeaderViewModel
    {
        Title = "Experience: Skyblivion Global Project",
        Subtitle = "Skyblivion",
        MetaLine = "Interior Level Designer | March 2021 - August 2022 | Ponte Vedra Beach, FL",
        LogoUrl = Url.Content("~/images/logos/skyblivion.png"),
        LogoAltText = "Skyblivion logo",
        LogoLinkUrl = "https://skyblivion.com/",
        LogoAriaLabel = "Skyblivion website"
    };
}

@await Html.PartialAsync("_ResumeDetailHeader", header)

<p>
    Collaborative game-development role on a distributed team with a focus on interior level design and technical iteration.
</p>

<ul>
    <li>Completed 11 detailed interior spaces for the project.</li>
    <li>Tested experimental workflows during project process transitions.</li>
    <li>Mentored new contributors for stronger onboarding and early delivery success.</li>
</ul>

<section class="mt-4">
    <h2 class="h5">Results</h2>
    <ul>
        <li>Completed 11 interiors delivered to the Skyblivion project.</li>
        <li>Contributed to team onboarding by mentoring new contributors.</li>
    </ul>
</section>

<section class="mt-4">
    <h2 class="h5">Tech Used</h2>
    <p class="mb-0">
        Creation Kit, Gamebryo, Level Design, Game Development.
    </p>
</section>

<section class="mt-4">
    <h2 class="h5">Selected Interiors</h2>
    <p class="text-muted">This page is the combined experience and project detailed view for Skyblivion.</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 project-gallery">
        <div class="col">
            <div class="card h-100">
                <img src="~/images/skyblivion/agarmirs-house.jpg" class="card-img-top" alt="Agarmir's House interior in Skyblivion" width="800" height="449" />
                <div class="card-body"><h3 class="h6 card-title mb-0">Agarmir's House</h3></div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <img src="~/images/skyblivion/dorians-house.jpg" class="card-img-top" alt="Dorian's House interior in Skyblivion" width="800" height="449" />
                <div class="card-body"><h3 class="h6 card-title mb-0">Dorian's House</h3></div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <img src="~/images/skyblivion/timberscar-hollow.jpg" class="card-img-top" alt="Timberscar Hollow interior in Skyblivion" width="800" height="415" />
                <div class="card-body"><h3 class="h6 card-title mb-0">Timberscar Hollow</h3></div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <img src="~/images/skyblivion/seridurs-house-basement.jpg" class="card-img-top" alt="Seridur's House Basement interior in Skyblivion" width="800" height="449" />
                <div class="card-body"><h3 class="h6 card-title mb-0">Seridur's House Basement (Order of the Virtuous Blood)</h3></div>
            </div>
        </div>
        <div class="col">
            <div class="card h-100">
                <img src="~/images/skyblivion/bruma-player-home.jpg" class="card-img-top" alt="Bruma Player Home interior in Skyblivion" width="800" height="450" />
                <div class="card-body"><h3 class="h6 card-title mb-0">Bruma Player Home</h3></div>
            </div>
        </div>
    </div>
</section>
